# Copy this file to .env.local and fill in your own key.
# Never commit .env.local — it holds a real secret.

ANTHROPIC_API_KEY=

# Optional — defaults to claude-haiku-4-5-20251001 if unset.
# Haiku keeps a 50-student classroom cheap and fast; swap to a stronger
# model for a quality comparison if you want to demo that tradeoff live.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Shared classroom passcode. Anyone who has this value can use the app —
# it's not per-user auth, just a gate so the URL isn't wide open to anyone
# who finds it. Pick something easy to say out loud in class.
NOMEN_KEY=
